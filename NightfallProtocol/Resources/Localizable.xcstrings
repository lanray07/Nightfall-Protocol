    "modifier.echoTrail.description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Echo remembers more of your route. Clean movement builds momentum."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El Eco recuerda mas de tu ruta. El movimiento limpio crea impulso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L Echo retient plus de ton trajet. Un mouvement net cree de l elan."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Echo merkt sich mehr deiner Route. Saubere Bewegung baut Momentum auf."
          }
        }
      }
    },
