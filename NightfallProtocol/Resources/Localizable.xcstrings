        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Everyone receives the same Daily Nightmare signal. Beat the code, extract clean, and share the recap."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos reciben la misma senal diaria. Supera el codigo, extrae limpio y comparte el resumen."
