    "tutorial.collapse.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Reality Collapse meter rises over time. High collapse triggers flicker, map shifts, surges, and exit relocation."
          }
        }
      }
    },
    "tutorial.collapse.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reality Collapse"
          }
        }
      }
    },
    "tutorial.enemies.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Entities adapt as collapse rises. Avoid detection, break contact, and never assume a patrol stays predictable."
          }
        }
      }
    },
    "tutorial.enemies.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adaptive Entities"
          }
        }
      }
    },
    "tutorial.extraction.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reach the extraction zone and interact before the collapse completes. Failed extraction loses temporary loot only."
          }
        }
      }
    },
    "tutorial.extraction.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extraction"
          }
        }
      }
    },
    "tutorial.inventory.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Artifacts, fragments, keys, tokens, cosmetics, and lore files are collected during missions."
          }
        }
      }
    },
    "tutorial.inventory.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Inventory"
          }
        }
      }
    },
    "tutorial.movement.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag or tap inside the nightmare zone to move. Keep distance from patrols and use rooms for cover."
          }
        }
      }
    },
    "tutorial.movement.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Movement"
          }
        }
      }
    },
    "tutorial.objectives.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Each mission rolls objectives at launch. Complete them for XP, loot, cosmetics, and lore unlocks."
          }
        }
      }
    },
    "tutorial.objectives.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Objectives"
          }
        }
      }
    },
    "tutorial.stealth.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Detection damages health and sanity. The Watcher sees movement, while the Echo follows your path."
          }
        }
      }
    },
    "tutorial.stealth.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stealth"
          }
        }
      }
    }
  },
