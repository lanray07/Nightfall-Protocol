        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout le monde recoit le meme signal quotidien. Bats le code, extrais proprement et partage le recap."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle erhalten dasselbe taegliche Signal. Besiege den Code, extrahiere sauber und teile den Bericht."
