    "modifier.glassMaze.description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extraction routes distort, but artifact chains are worth more."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las rutas de extraccion se distorsionan, pero las cadenas de artefactos valen mas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les routes d extraction se tordent, mais les chaines d artefacts valent plus."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Extraktionsrouten verzerren sich, aber Artefaktketten zaehlen mehr."
          }
        }
