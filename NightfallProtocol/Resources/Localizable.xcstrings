          }
        }
      }
    },
    "lore.artifact.01": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file describes a room that appeared inside three unrelated dreams."
          }
        }
      }
    },
    "lore.artifact.02": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A recovered signal repeats the operator's name before they speak it."
          }
        }
      }
    },
    "lore.artifact.03": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The artifact vibrates when a false exit is nearby."
          }
        }
      }
    },
    "lore.artifact.04": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No camera recorded the pickup, but every camera recorded the return."
          }
        }
      }
    },
    "lore.artifact.05": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A black-site memo labels the object as evidence and witness."
          }
        }
      }
    },
    "lore.artifact.06": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The protocol sealed the entry twice. The second seal is handwritten."
          }
        }
      }
    },
    "lore.briefing.01": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A low signal is leaking from a room that was never built. Recover proof and leave before it notices."
          }
        }
      }
    },
    "lore.briefing.02": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The dream keeps rearranging its own evidence. Trust the scanner, not the walls."
          }
        }
      }
    },
    "lore.briefing.03": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An echo requested extraction using your voice. Confirm identity, then break contact."
          }
        }
      }
    },
    "lore.briefing.04": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The rift is widening under the archive floor. Seal it before the lights learn your route."
          }
        }
      }
    },
    "lore.briefing.05": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A black-site corridor has returned with new doors. Investigate only what you can carry out."
          }
        }
      }
    },
    "lore.briefing.06": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The nightmare is quiet. That usually means it has started counting."
          }
        }
      }
    },
