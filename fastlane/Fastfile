require "base64"
require "fileutils"
require "json"
require "shellwords"

default_platform(:ios)

def nightfall_api_key
  key = ENV["ASC_KEY_P8_BASE64"]
  UI.user_error!("Set ASC_KEY_ID, ASC_ISSUER_ID, and ASC_KEY_P8_BASE64 in GitHub Secrets.") if key.to_s.empty?

  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: Base64.decode64(key),
    is_key_content_base64: false,
    duration: 1200,
    in_house: false
  )
end

def app_review_information_payload
  required = {
    first_name: ENV["APP_REVIEW_FIRST_NAME"],
    last_name: ENV["APP_REVIEW_LAST_NAME"],
    phone_number: ENV["APP_REVIEW_PHONE"],
    email_address: ENV["APP_REVIEW_EMAIL"]
  }

  missing = required.select { |_key, value| value.to_s.empty? }.keys
  if missing.any?
    UI.important("Skipping App Review contact upload. Missing secrets: #{missing.join(', ')}")
    return nil
  end

  required.merge(notes: File.read(File.expand_path("review_notes.txt", __dir__)).strip)
end

def nightfall_build_number
  ENV.fetch("BUILD_NUMBER", ENV.fetch("GITHUB_RUN_NUMBER", Time.now.utc.strftime("%Y%m%d%H%M")))
end

def nightfall_signing_args(team_id:, profile_specifier:, signing_certificate:)
  [
    "DEVELOPMENT_TEAM=#{Shellwords.escape(team_id)}",
    "CURRENT_PROJECT_VERSION=#{Shellwords.escape(nightfall_build_number)}",
    "CODE_SIGN_STYLE=Manual",
    "CODE_SIGNING_ALLOWED=YES",
    "CODE_SIGN_IDENTITY=#{Shellwords.escape(signing_certificate)}",
    "PROVISIONING_PROFILE_SPECIFIER=#{Shellwords.escape(profile_specifier)}"
  ]
end

def nightfall_export_auth_args
  [
    "-allowProvisioningUpdates",
    "-authenticationKeyPath #{Shellwords.escape(ENV.fetch("ASC_KEY_PATH"))}",
    "-authenticationKeyID #{Shellwords.escape(ENV.fetch("ASC_KEY_ID"))}",
    "-authenticationKeyIssuerID #{Shellwords.escape(ENV.fetch("ASC_ISSUER_ID"))}"
  ].join(" ")
end

def nightfall_build_and_upload(platform_key:, destination:, sdk:, profile_env:, default_profile:, artifact_name:, catalyst_platform: nil, app_platform: nil, installer_cert_env: nil, signing_certificate_env: nil, default_signing_certificate: "Apple Distribution", automatic_signing: false, manual_package_pkg: false)
  team_id = ENV["APPLE_TEAM_ID"]
  UI.user_error!("Set APPLE_TEAM_ID in GitHub Secrets before uploading a signed App Store build.") if team_id.to_s.empty?

  profile_specifier = ENV.fetch(profile_env, default_profile)
  signing_certificate = if signing_certificate_env && !ENV[signing_certificate_env].to_s.empty?
    ENV[signing_certificate_env]
  else
    default_signing_certificate
  end
  output_directory = "build/export/#{platform_key}"
  archive_path = "build/NightfallProtocol-#{platform_key}.xcarchive"
  api_key = nightfall_api_key
  signing_xcargs = if automatic_signing
    [
      "DEVELOPMENT_TEAM=#{Shellwords.escape(team_id)}",
      "CURRENT_PROJECT_VERSION=#{Shellwords.escape(nightfall_build_number)}",
      "CODE_SIGN_STYLE=Automatic",
      "CODE_SIGNING_ALLOWED=YES",
      "-allowProvisioningUpdates",
      "-authenticationKeyPath #{Shellwords.escape(ENV.fetch("ASC_KEY_PATH"))}",
      "-authenticationKeyID #{Shellwords.escape(ENV.fetch("ASC_KEY_ID"))}",
      "-authenticationKeyIssuerID #{Shellwords.escape(ENV.fetch("ASC_ISSUER_ID"))}"
    ]
  else
    nightfall_signing_args(team_id: team_id, profile_specifier: profile_specifier, signing_certificate: signing_certificate)
  end

  export_options = if automatic_signing
    {
      signingStyle: "automatic",
      teamID: team_id,
      manageAppVersionAndBuildNumber: false
    }
  else
    {
      signingStyle: "manual",
      signingCertificate: signing_certificate,
      teamID: team_id,
      provisioningProfiles: {
        "com.nightfallprotocol.prototype" => profile_specifier
      },
      manageAppVersionAndBuildNumber: false
    }
  end

  build_options = {
    project: "NightfallProtocol.xcodeproj",
    scheme: "NightfallProtocol",
    configuration: "Release",
    clean: true,
    sdk: sdk,
    destination: destination,
    archive_path: archive_path,
    output_directory: output_directory,
    output_name: artifact_name,
    export_method: "app-store",
    include_symbols: true,
    include_bitcode: false,
    xcodebuild_formatter: "",
    xcargs: signing_xcargs.join(" "),
    export_xcargs: nightfall_export_auth_args,
    export_options: export_options
  }
  build_options[:catalyst_platform] = catalyst_platform if catalyst_platform
  if installer_cert_env && !ENV[installer_cert_env].to_s.empty?
    build_options[:installer_cert_name] = ENV[installer_cert_env]
    build_options[:export_options][:installerSigningCertificate] = ENV[installer_cert_env]
  end

  artifact = nil
  if manual_package_pkg
    installer_cert_name = installer_cert_env && ENV[installer_cert_env]
    UI.user_error!("Set #{installer_cert_env} before manually packaging a Mac installer.") if installer_cert_name.to_s.empty?

    repo_root = File.expand_path("..", __dir__)
    project_path = File.join(repo_root, "NightfallProtocol.xcodeproj")
    archive_path_absolute = File.expand_path(archive_path, repo_root)
    output_directory_absolute = File.expand_path(output_directory, repo_root)

    FileUtils.rm_rf(archive_path_absolute)
    FileUtils.rm_rf(output_directory_absolute)
    FileUtils.mkdir_p(File.dirname(archive_path_absolute))
    FileUtils.mkdir_p(output_directory_absolute)
    sh([
      "xcodebuild",
      "-project #{Shellwords.escape(project_path)}",
      "-scheme NightfallProtocol",
      "-configuration Release",
      "-sdk #{Shellwords.escape(sdk)}",
      "-destination #{Shellwords.escape(destination)}",
      "-archivePath #{Shellwords.escape(archive_path_absolute)}",
      "clean",
      "archive",
      signing_xcargs.join(" ")
    ].join(" "))

    archived_apps = Dir[File.join(archive_path_absolute, "**", "*.app")]
    UI.user_error!("Archived Mac app was not found under #{archive_path_absolute}.") if archived_apps.empty?
    app_path = archived_apps.first

    artifact = File.join(output_directory_absolute, "#{artifact_name}.pkg")
    sh([
      "xcrun productbuild",
      "--sign #{Shellwords.escape(installer_cert_name)}",
      "--component #{Shellwords.escape(app_path)}",
      "/Applications",
      Shellwords.escape(artifact)
    ].join(" "))
  else
    build_app(**build_options)
    artifact = lane_context[SharedValues::IPA_OUTPUT_PATH] || lane_context[SharedValues::PKG_OUTPUT_PATH]
    artifact ||= (Dir[File.join(output_directory, "*.ipa")] + Dir[File.join(output_directory, "*.pkg")]).first
  end
  UI.user_error!("No uploadable artifact was produced in #{output_directory}.") if artifact.to_s.empty?

  upload_options = {
    api_key: api_key,
    app_identifier: ENV.fetch("APP_IDENTIFIER", "com.nightfallprotocol.prototype"),
    skip_waiting_for_build_processing: true,
    uses_non_exempt_encryption: false
  }
  upload_options[:app_platform] = app_platform if app_platform

  if artifact.end_with?(".pkg")
    upload_options[:pkg] = artifact
  else
    upload_options[:ipa] = artifact
  end

  upload_to_testflight(**upload_options)
end

platform :ios do
  desc "Archive Nightfall Protocol for iOS and upload the signed IPA to TestFlight."
  lane :build_upload_ios do
    nightfall_build_and_upload(
      platform_key: "ios",
      destination: "generic/platform=iOS",
      sdk: "iphoneos",
      profile_env: "PROFILE_SPECIFIER",
      default_profile: "NightfallProtocol_App_Store",
      artifact_name: "NightfallProtocol-iOS.ipa"
    )
  end

  desc "Archive Nightfall Protocol and upload the signed iOS IPA to TestFlight."
  lane :build_upload do
    build_upload_ios
  end

  desc "Upload App Store metadata and screenshots without submitting for review."
  lane :metadata do
    options = {
      api_key: nightfall_api_key,
      metadata_path: "fastlane/metadata",
      screenshots_path: "fastlane/screenshots",
      skip_binary_upload: true,
      submit_for_review: false,
      force: true,
      overwrite_screenshots: true,
      automatic_release: true,
      run_precheck_before_submit: false
    }

    review_payload = app_review_information_payload
    options[:app_review_information] = review_payload if review_payload

    deliver(**options)
  end

  desc "Upload privacy policy metadata required for App Review."
  lane :privacy_metadata do
    shared_options = {
      api_key: nightfall_api_key,
      metadata_path: "fastlane/metadata",
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: false,
      force: true,
      run_precheck_before_submit: false
    }

    deliver(**shared_options.merge(platform: "ios"))
  end

  desc "Print the cosmetic-only in-app purchase manifest for App Store setup."
  lane :iap_manifest do
    UI.message(JSON.pretty_generate(JSON.parse(File.read("fastlane/iap_products.json"))))
  end
end
